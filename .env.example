# 复制为 .env.local 后填写（不要提交 .env.local）
# 修改后需重启：npm run dev（Next 不会热重载新环境变量）
#
# 推荐：只配 SILICONFLOW_API_KEY（本地与 Vercel 均生效）。前端默认不带头，由服务端读此变量。
# 可选：用户在站内「API」自填 → 浏览器存 localStorage 并带头覆盖。
# 可选：NEXT_PUBLIC_SILICONFLOW_API_KEY（会暴露给浏览器，一般不必配）

SILICONFLOW_API_KEY=
# NEXT_PUBLIC_SILICONFLOW_API_KEY=
# 须在硅基流动控制台与文档中核对；旧版 Qwen2.5-72B 等可能已下线导致 404
SILICONFLOW_MODEL=Qwen/Qwen3.5-397B-A17B
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 可选：背景音乐绝对 URL（默认用本站 /audio/prosecco.mp3，需将 mp3 放在 public/audio 并提交 Git）
# 示例（jsDelivr 指向 GitHub 仓库内文件）：NEXT_PUBLIC_AUDIO_SRC=https://cdn.jsdelivr.net/gh/你的用户/你的仓库@main/public/audio/prosecco.mp3
# NEXT_PUBLIC_AUDIO_SRC=
